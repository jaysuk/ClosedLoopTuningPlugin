{
  "name": "closed-loop-tuning",
  "version": "2.0.0",
  "description": "Tune and visualise the Duet closed-loop driver (1HCL / M23CL): mode + calibration control, guided PID tuning, automatic step-response analysis — a Duet Web Control 3.7 plugin.",
  "private": true,
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/jaysuk/ClosedLoopTuningPlugin",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "dwc-plugin-typecheck",
    "verify-build": "dwc-plugin-verify-build",
    "release-title": "node scripts/release-title.mjs",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "dwc-plugin-runtime": "github:jaysuk/dwc-plugin-runtime#v0.6.1",
    "chart.js": "^4.4.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.6",
    "dwc-plugin-test-kit": "github:jaysuk/dwc-plugin-test-kit#v0.2.4",
    "happy-dom": "^15.11.7",
    "vitest": "^4.1.8",
    "vue": "^3.5.30",
    "vuetify": "^4.1.0"
  }
}
